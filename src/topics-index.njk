---
layout: base.njk
permalink: /topics/
pageTitle: Topics
pageDescription: Browse essays by topic — AI, race, film, religion, surveillance, sports, and personal writing.
---

<section class="section">
  <div class="container container--narrow">
    <header class="page-header">
      <h1>Topics</h1>
      <p>Every essay is filed under one topic. Pick one to dive in.</p>
    </header>

    <ul class="topic-grid">
      {% for topic in topics %}
        {% set count = (collections.posts | selectattr("topic", "equalto", topic.slug)).length %}
        <li>
          <a href="/topics/{{ topic.slug }}/" class="topic-card">
            <h2>{{ topic.name }}</h2>
            <p>{{ topic.intro }}</p>
            <p class="topic-card__count">{{ count }} essay{% if count != 1 %}s{% endif %}</p>
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
</section>
